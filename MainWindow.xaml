<Window x:Class="CybersecurityAwarenessBotPart2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - Part 2" Height="720" Width="1050"
        WindowStartupLocation="CenterScreen" Background="#08111F">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="18" Padding="18" Background="#111C2E" BorderBrush="#2F80ED" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="115" Height="115" CornerRadius="20" Background="#0B1324" BorderBrush="#22C55E" BorderThickness="1">
                    <TextBlock x:Name="AsciiArtBlock" FontFamily="Consolas" FontSize="10" Foreground="#22C55E"
                               TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Cybersecurity Awareness Bot" FontSize="30" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Part 2 WPF GUI • Keyword Recognition • Memory • Sentiment Detection • Random Responses"
                               FontSize="15" Foreground="#B9C7DA" Margin="0,6,0,0" />
                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Password" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                        <Button Content="Phishing" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                        <Button Content="Privacy" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                        <Button Content="Scam" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                        <Button Content="Malware" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                        <Button Content="2FA" Click="QuickTopic_Click" Style="{StaticResource TopicButton}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="18" Padding="16" Margin="0,16" Background="#0E1728" BorderBrush="#24344D" BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatPanel" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" CornerRadius="18" Padding="14" Background="#111C2E" BorderBrush="#2F80ED" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UserInputBox" Height="48" FontSize="16" Padding="14,10" Background="#08111F" Foreground="White"
                         BorderBrush="#334155" BorderThickness="1" KeyDown="UserInputBox_KeyDown"
                         Text="Type your cybersecurity question here..." GotFocus="UserInputBox_GotFocus" />
                <Button Grid.Column="1" Content="Send" Margin="12,0,0,0" Click="SendButton_Click" Style="{StaticResource MainButton}" />
                <Button Grid.Column="2" Content="Clear" Margin="12,0,0,0" Click="ClearButton_Click" Style="{StaticResource ClearButton}" />
            </Grid>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style x:Key="ClearButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#334155" />
        </Style>
        <Style x:Key="TopicButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="#16243A" />
            <Setter Property="Foreground" Value="#DDE7F3" />
            <Setter Property="BorderBrush" Value="#2F80ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
</Window>
